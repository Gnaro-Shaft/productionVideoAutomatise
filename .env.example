# ─────────────────────────────────────────────
# Database (Postgres — Docker Compose)
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://pva:pva@localhost:5432/pva?schema=public"

# ─────────────────────────────────────────────
# Local single-user (V1) — filled by `pnpm db:seed`
# ─────────────────────────────────────────────
LOCAL_ORG_ID=
LOCAL_USER_ID=

# ─────────────────────────────────────────────
# Storage — MinIO local (S3-compatible)
# ─────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=pva-assets

# ─────────────────────────────────────────────
# Temporal — workflow orchestration
# ─────────────────────────────────────────────
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default

# ─────────────────────────────────────────────
# Redis — cache, idempotency
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────
# LLM (OpenAI-compatible — works with Ollama, MLX, vLLM, …)
# ─────────────────────────────────────────────
# Ollama:  LLM_BASE_URL=http://localhost:11434/v1   LLM_MODEL=qwen2.5:14b-instruct-q5_K_M
# MLX:     LLM_BASE_URL=http://localhost:8080/v1    LLM_MODEL=mlx-community/Qwen2.5-14B-Instruct-4bit
# vLLM:    LLM_BASE_URL=http://localhost:8000/v1    LLM_MODEL=<deployed name>
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen2.5:14b-instruct-q5_K_M
LLM_API_KEY=not-needed

# ─────────────────────────────────────────────
# ComfyUI — image / video gen (runs natively on Mac, MPS)
# ─────────────────────────────────────────────
COMFY_URL=http://localhost:8188

# ─────────────────────────────────────────────
# Python services (run natively on Mac)
# ─────────────────────────────────────────────
PLANNER_SVC_URL=http://localhost:7001
VOICE_SVC_URL=http://localhost:7002
MUSIC_SVC_URL=http://localhost:7003
SFX_SVC_URL=http://localhost:7004
LIPSYNC_SVC_URL=http://localhost:7005
TRANSLATE_SVC_URL=http://localhost:7006
RENDER_SVC_URL=http://localhost:7007

# ─────────────────────────────────────────────
# API gateway (NestJS)
# ─────────────────────────────────────────────
API_PORT=4000
API_CORS_ORIGIN=http://localhost:3000

# ─────────────────────────────────────────────
# Web frontend (Next.js)
# ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000
